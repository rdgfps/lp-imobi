# Banco de dados
# Local:
DATABASE_URL="postgresql://usuario:senha@localhost:5432/imoveis_db"

# Supabase/Vercel:
# Use a connection string PostgreSQL do Supabase com SSL.
# Exemplo de pooler:
# DATABASE_URL="postgresql://postgres.xxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Auth.js / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-uma-chave-secreta-forte-com-32-caracteres-minimo"
# Se o Auth.js reclamar do host em produção, habilite:
# AUTH_TRUST_HOST="true"

# Site
NEXT_PUBLIC_WHATSAPP_NUMBER="5553999999999"
NEXT_PUBLIC_SITE_NAME="Canguçu Imóveis"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Uploads
# Em produção na Vercel, use "supabase" ou "s3". O modo "local" é apenas para desenvolvimento.
STORAGE_PROVIDER="local"

# Supabase Storage
# Crie um bucket público, por exemplo: imoveis
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
SUPABASE_STORAGE_BUCKET="imoveis"

# S3, caso prefira AWS
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
S3_PUBLIC_URL=""
