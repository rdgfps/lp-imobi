# ===== VARIÁVEIS DE AMBIENTE =====
# Copie para .env.local e configure seus valores

# ===== BANCO DE DADOS =====
# PostgreSQL: postgresql://usuario:senha@host:porta/banco
DATABASE_URL="postgresql://usuario:senha@localhost:5432/imoveis_db"

# ===== AUTENTICAÇÃO (NextAuth) =====
# URL da aplicação (local ou produção)
NEXTAUTH_URL="http://localhost:3000"

# Chave secreta para assinar tokens JWT
# ⚠️ IMPORTANTE: Gerar chave forte em produção!
# Comando: openssl rand -base64 32
NEXTAUTH_SECRET="gere-uma-chave-secreta-forte-com-32-caracteres-minimo"

# ===== WHATSAPP =====
# Número apenas com dígitos (55 + DDD + número)
NEXT_PUBLIC_WHATSAPP_NUMBER="5553999999999"

# ===== CONFIGURAÇÕES DO SITE =====
# Nome da imobiliária
NEXT_PUBLIC_SITE_NAME="Canguçu Imóveis"

# URL do site (usada em meta tags e links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===== ARMAZENAMENTO DE UPLOADS =====
# Por padrão o projeto usa armazenamento local (pasta `public/uploads`) para desenvolvimento.
# Em produção (Vercel) configure `STORAGE_PROVIDER` como `s3` e ajuste as variáveis abaixo.
STORAGE_PROVIDER="local" # ou "s3"

# Se usar S3 (AWS) - preencha com as credenciais e bucket
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
# Opcional: URL pública customizada (ex: https://cdn.example.com)
S3_PUBLIC_URL=""
